{
	"name": "sailing-architects",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"email:handoff": "node --env-file=.env scripts/send-handoff-report.mjs",
		"email:test": "node --env-file=.env scripts/send-test-email.mjs"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@wuchale/svelte": "^0.19.3",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wuchale": "^0.22.11"
	},
	"dependencies": {
		"@clerk/clerk-js": "^6.7.7",
		"@clerk/localizations": "^4.5.5",
		"@stripe/stripe-js": "^9.3.0",
		"convex": "^1.36.0",
		"convex-svelte": "^0.0.12",
		"stripe": "^22.0.2",
		"svelte-clerk": "^1.1.5"
	}
}
