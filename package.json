{
	"name": "sailing-architects",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"codex:start": "node scripts/codex-session-start.mjs",
		"codex:stop": "node scripts/codex-session-stop.mjs",
		"codex:compact": "node scripts/codex-session-stop.mjs",
		"email:handoff": "node --env-file=.env scripts/send-handoff-report.mjs",
		"email:handoff:yesterday": "node --env-file=.env scripts/send-yesterday-handoff-report.mjs",
		"email:test": "node --env-file=.env scripts/send-test-email.mjs"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/pdfkit": "^0.17.6",
		"@wuchale/svelte": "^0.19.3",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.0.7",
		"vitest": "^4.1.10",
		"wuchale": "^0.22.11"
	},
	"dependencies": {
		"@clerk/clerk-js": "^6.7.7",
		"@clerk/localizations": "^4.5.5",
		"@convex-dev/migrations": "^0.3.5",
		"@stripe/stripe-js": "^9.3.0",
		"convex": "^1.36.0",
		"convex-svelte": "^0.0.12",
		"dejavu-fonts-ttf": "^2.37.3",
		"pdfkit": "^0.18.0",
		"stripe": "^22.0.2",
		"svelte-clerk": "^1.1.5",
		"zod": "^4.3.6"
	}
}
