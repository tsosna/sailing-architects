# Convex (wypełniane automatycznie przez `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment-name
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Clerk
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Brevo transactional email
BREVO_API_KEY=
BREVO_FROM_EMAIL=
CONTACT_EMAIL=

# Base URL used in transactional emails (link "Otwórz panel")
PUBLIC_APP_URL=https://sailing-architects.wysokijohn.pl
